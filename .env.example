# ── Auth gate ────────────────────────────────────────────────────────────────
# Required. The middleware fails CLOSED (503) when this is unset, and the
# /login form + every gated API route compare the `acuterium-access` cookie
# against it. Without it the dashboard is unreachable.
DASHBOARD_ACCESS_TOKEN=

# ── Google Sheets data layer ─────────────────────────────────────────────────
# GOOGLE_SHEET_ID is the 44-char ID from the sheet URL.
# The service-account email + PEM private key are read under EITHER naming
# convention — set the GOOGLE_SHEETS_* pair OR the SERVICE_ACCOUNT pair (the
# write client falls back across both). Use ONE pair consistently.
GOOGLE_SHEET_ID=
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
# Aliases (equivalent — used by the legacy read adapter, accepted by the write client):
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY=

SEED_SECRET=

NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
